@page "/orderdetails/delete"
@using Microsoft.EntityFrameworkCore
@using DataAccess
@using SengWeb.Data
@inject IDbContextFactory<SengWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Order Detail</PageTitle>

<h1>Delete Order Detail</h1>

<p>Are you sure you want to delete this product from the order?</p>

@if (orderdetail is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div>
        <h2>Order Detail</h2>
        <hr />

        <dl class="row">
            <dt class="col-sm-2">Order</dt>
            <dd class="col-sm-10">Order #@orderdetail.OrderID</dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Customer</dt>
            <dd class="col-sm-10">@(orderdetail.Order?.Customer?.Name ?? "No Customer")</dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Product</dt>
            <dd class="col-sm-10">@(orderdetail.Product?.Name ?? "No Product")</dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Quantity</dt>
            <dd class="col-sm-10">@orderdetail.Quantity</dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Subtotal</dt>
            <dd class="col-sm-10">@orderdetail.Subtotal</dd>
        </dl>

        <dl class="row">
            <dt class="col-sm-2">Last Modified</dt>
            <dd class="col-sm-10">@orderdetail.LastModified</dd>
        </dl>

        <EditForm method="post" Model="orderdetail" OnValidSubmit="DeleteOrderDetail" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger">Delete</button> |
            <a href="/orderdetails">Back to List</a>
        </EditForm>
    </div>
}

@code {
    private OrderDetail? orderdetail;

    [SupplyParameterFromQuery]
    private int OrderID { get; set; }

    [SupplyParameterFromQuery]
    private int ProductID { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        orderdetail = await context.OrderDetail
            .Include(od => od.Product)
            .Include(od => od.Order)
                .ThenInclude(o => o.Customer)
            .FirstOrDefaultAsync(od =>
                od.OrderID == OrderID &&
                od.ProductID == ProductID);

        if (orderdetail is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task DeleteOrderDetail()
    {
        using var context = DbFactory.CreateDbContext();

        var detailToDelete = await context.OrderDetail
            .FirstOrDefaultAsync(od =>
                od.OrderID == OrderID &&
                od.ProductID == ProductID);

        if (detailToDelete is null)
        {
            NavigationManager.NavigateTo("notfound");
            return;
        }

        var product = await context.Product
            .FirstOrDefaultAsync(p => p.ProductID == ProductID);

        var order = await context.Order
            .FirstOrDefaultAsync(o => o.OrderID == OrderID);

        if (product is not null)
        {
            product.StockQuantity += detailToDelete.Quantity;
            product.Availability = true;
            product.LastModified = DateTime.Now;
        }

        if (order is not null)
        {
            order.TotalAmount -= detailToDelete.Subtotal;

            if (order.TotalAmount < 0)
            {
                order.TotalAmount = 0;
            }

            order.LastModified = DateTime.Now;
        }

        context.OrderDetail.Remove(detailToDelete);

        await context.SaveChangesAsync();

        NavigationManager.NavigateTo("/orderdetails");
    }
}